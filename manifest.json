{
  "manifest_version": 3,
  "name": "KeepUp",
  "version": "1.0.0",
  "description": "Smart bookmarking for sequential content. Track manga chapters, course lectures, episodes, and more with automatic updates.",
  "author": "Matteo Camillo",
  "homepage_url": "https://github.com/MatteoCamillo-code/keepup",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "KeepUp - Track sequential content",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "usermail@mail.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}